                     163     ; Calculating file length
  0080               164     FILE_LEN EQU (MY_FILE_END - MY_FILE)
                     165     ;--- ROBUST CRC-8 CALCULATION ---
                     166     ; Polynomial: X^8 + X^5 + X^4 + 1 (0x31)
0101                 167     CALC_CHECKSUM:
0101 9001C0          168         MOV DPTR, #MY_FILE
0104 7F80            169         MOV R7, #FILE_LEN         ; Check 10 bytes
0106 7800            170         MOV R0, #00H        ; R0 holds the CRC remainder (Initial value 0)
                     171         
0108                 172     BYTE_LOOP:
0108 E4              173         CLR A
0109 93              174         MOVC A, @A+DPTR     ; Get byte from "File"
010A 68              175         XRL A, R0           ; XOR byte with current CRC
010B F8              176         MOV R0, A           
                     177         
010C 7E08            178         MOV R6, #8          ; Process 8 bits
010E                 179     BIT_LOOP:
010E E8              180         MOV A, R0
010F 33              181         RLC A               ; Shift MSB into Carry
0110 5002            182         JNC SHIFT_ONLY      ; If Carry is 0, just shift
                     183         
                     184         ; If Carry is 1, XOR with Polynomial 0x31
0112 6431            185         XRL A, #31H         
0114                 186     SHIFT_ONLY:
0114 F8              187         MOV R0, A           ; Store updated CRC
0115 DEF7            188         DJNZ R6, BIT_LOOP   ; Repeat for all 8 bits
                     189         
